# Notion Integration Secret (docs/guides/notion-setup.md 참조)
NOTION_API_KEY=secret_xxxxxxxxxxxxx
# Invoices 데이터베이스 ID
NOTION_DATABASE_ID=xxxxxxxxxxxxx

# 배포된 서비스의 공개 URL (선택, 프로덕션 배포 시 설정 - docs/guides/deployment.md 참조)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# E2E 테스트(Playwright)에서 실제 Notion 데이터로 검증할 견적서 페이지 ID (선택, 로컬 테스트 전용)
# E2E_INVOICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
